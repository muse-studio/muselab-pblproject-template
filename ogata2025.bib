@article{rpg,
  title = {{ロールプレイングゲームシナリオにおける クエスト構造に着目した物語分析}},
  author = {{石川 一稀} and {中村 祥吾} and {宇田 朗子} and {斉藤 勇璃} and {根本 さくら} and 恭介, 長野 and 拓真, 山内 and 智誠, 白石 and 和宏, 太田 and 武, 稲垣 and 源, 村井 and 圭二, 平田 and 和司, 迎山 and 恵美子, 田柳},
  year = {2020},
