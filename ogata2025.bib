@article{sinwa,
  title = {{神話物語と神話を原型にした現代物語の構造比較}},
  author = {{吉田 拓海} and {村井 源}},
  year = {2021},
  month = may,
  journal = {情報知識学会誌},
  volume = {31},
  number = {2},
  pages = {318--324},
  publisher = {情報知識学会},
  urldate = {2024-06-06},
  abstract = {\&lt;p\&gt;　神話は物語の原型であると考えられており，物語自動生成において神話物語は大きな価値があるといえる．しかし，シンプルかつ基本的な物語構造をもつ神話とは異なり，現代物語の構造は複雑であると考えられている．そこで，神話物語の構造と神話を原型にした現代物語の構造を比較し，原型から物語生成を行う方法を考察する．分析の結果，神話物語の主人公の行動と現代物語の主人公の行動に異なる構造が存在することが明らかになった．\&lt;/p\&gt;},
  langid = {japanese},
  note = {https://x.gd/Zqhro}
}

@article{sokyu,
  title = {物語の訴求構造分析の理論と手法及び応用事例},
  author = {{高田 明典}},
  year = {2020},
  journal = {電子情報通信学会 基礎・境界ソサイエティ Fundamentals Review},
  volume = {14},
  number = {2},
  pages = {118--137},
  publisher = {一般社団法人 電子情報通信学会},
  abstract = {私たちの社会における価値観の形成に関して，「物語」が果たす役割は決して小さくない．物語は，この社会の価値観を形成し変化させうるものであると考える．本論文では，物語分析のうち，特に物語の訴求力を分析する方法としての「物語訴求構造分析」について論じる．まず，物語論及び物語分析の基礎となる理論を説明する．続いて，物語分析及び物語論の研究史を概観する．また，物語分析において用いられる主要な手法について概観し，その概要について述べ，物語の訴求構造分析手法の応用例を提示する．},
  keywords = {Appealing power,Narrative,Narrative analysis,Narratology,Structuralism,構造主義,物語,物語分析,物語論,訴求力},
  note = {https://x.gd/7sagx}
}

@article{suiri,
  title = {{物語自動生成のための推理小説中の伏線分類}},
  author = {{青山 美月}},
  year = {2022},
  month = dec,
  journal = {じんもんこん2022論文集},
  volume = {2022},
  pages = {145--150},
  urldate = {2024-06-06},
  abstract = {近年，推理小説においてプロットの自動生成や，トリックと動機の自動生成などの研究が行われている． 本研究では，古典作品と現代作品合わせて174 話を対象とし，伏線を含む推理小説の自動生成のため推理小説に含まれる伏線の分類を行った．その結果，推理小説に含まれやすい伏線の構造が判明した．また，古典作品と現代作品で，伏線によって示唆される情報に変化が生じることが明らかになった．このことから伏線には，示唆される情報によって用いられやすい方法が存在し，その構造は物語を魅力的に見せる役割があると考察できる．また示唆される情報は，物語に手軽に新規性を出すために様々な要素を加えた結果変化が生じたのだと考えられる． In recent years, research has been conducted on the automatic generation of plots, tricks, and motives. In this study, we classified foreshadowing in 174 episodes of classical and modern works for automatic generation of mystery stories containing foreshadowing and found the structure of foreshadowing. The structure of foreshadowing was found to have changed between classic and modern works. As a result, it can be considered that there is a method that is easily used depending on the information suggested, and that it is used to make the story more attractive. The suggested information can also be attributed to the addition of various elements in order to create novelty in the story.},
  langid = {japanese},
  note = {https://cir.nii.ac.jp/crid/1050294643541504000}
}

