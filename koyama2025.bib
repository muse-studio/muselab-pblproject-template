@article{Hirose94,
  title = {音声の基本周波数パターンにおける話者の意図 感情の表現},
  author = {{広瀬 啓吉} and {高橋 登} and {藤崎 博也} and {大野 澄雄}},
  year = {1994},
  journal = {信学技報},
  volume = {94},
  pages = {33--40},
  publisher = {一般社団法人電子情報通信学会},
  urldate = {2024-12-18},
  abstract = {音声言語における話者の意図・感情と基本周波数パターンの関係を合成音声の知覚実験と自然音声の分析によって調べた。意図に関しては、基本周波数パターンを系統的に制御した合成音声を用いて聴取試験を行い、自然音声の分析結果を裏付ける結果が得られた。感情に関しては、同一の内容を異なる感情で発声した音声を比較分析し、感情とアクセント指令の大きさ・位置等の韻律に関連してパラメータとの関連を明らかにした。},
  keywords = {パラ言語情報,基本周波数パターン,意図,感情,非言語情報,韻律 的特徴},
  note = {https://cir.nii.ac.jp/crid/1570009752499942528}
}

